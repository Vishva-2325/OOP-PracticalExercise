import java.util.*;

class WordFreq {
    public static void main(String[] args) {
        String str = "Java is fun and Java is powerful";
        HashMap<String,Integer> map = new HashMap<>();

        for(String w : str.split(" ")){
            map.put(w, map.getOrDefault(w,0)+1);
        }

        System.out.println(map);
    }
}
