class T extends Thread {
    int start, end;

    T(int s, int e) { start=s; end=e; }

    public void run() {
        for(int i=start;i<=end;i++)
            System.out.println(i);
    }
}

class MainThread {
    public static void main(String[] args) throws Exception {
        T t1 = new T(1,100);
        T t2 = new T(101,200);
        T t3 = new T(201,300);

        t1.start(); t1.join();
        t2.start(); t2.join();
        t3.start();
    }
}
