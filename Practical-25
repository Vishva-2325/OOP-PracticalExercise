class Table {
    synchronized void print(int n) {
        for(int i=1;i<=10;i++)
            System.out.println(n*i);
    }
}

class A extends Thread {
    Table t;
    A(Table t){this.t=t;}
    public void run(){t.print(5);}
}

class B extends Thread {
    Table t;
    B(Table t){this.t=t;}
    public void run(){t.print(7);}
}

class Test {
    public static void main(String[] args) {
        Table t = new Table();
        new A(t).start();
        new B(t).start();
    }
}
