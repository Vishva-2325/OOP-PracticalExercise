class College {
    String collegeName;

    College(String name) {
        collegeName = name;
    }

    class Admission {
        String studentName, course;

        void setData(String n, String c) {
            studentName = n;
            course = c;
        }

        void display() {
            System.out.println(collegeName + " " + studentName + " " + course);
        }
    }

    public static void main(String[] args) {
        College c = new College("ABC College");
        College.Admission a = c.new Admission();
        a.setData("John", "CS");
        a.display();
    }
}
