import java.util.*;

class Search {
    static <T> boolean searchElement(LinkedList<T> list, T e) {
        return list.contains(e);
    }

    public static void main(String[] args) {
        LinkedList<Integer> l1 = new LinkedList<>();
        l1.add(1); l1.add(2);

        System.out.println(searchElement(l1,2));
    }
}
