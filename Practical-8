class Point {
    int x, y;

    Point() {
        x = y = 5;
    }

    Point(int x, int y) {
        this.x = x;
        this.y = y;
    }

    Point(Point p) {
        x = p.x;
        y = p.y;
    }

    void display() {
        System.out.println(x + "," + y);
    }

    public static void main(String[] args) {
        Point p1 = new Point();
        Point p2 = new Point(2,3);
        Point p3 = new Point(p2);

        p1.display();
        p2.display();
        p3.display();
    }
}
